[Unit]
Description=Dufs file share
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=muskr
Group=muskr
WorkingDirectory=/home/muskr/code/dufs
ExecStart=/home/muskr/code/dufs/target/release/dufs --config /home/muskr/code/dufs/dufs-share.yaml
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
